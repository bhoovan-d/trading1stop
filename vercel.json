{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "functions": {
    "api/index.py": {
      "includeFiles": "src/**",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api", "dest": "/api/index" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

