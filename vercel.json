{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "functions": {
    "api/index.py": {
      "includeFiles": "src/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

