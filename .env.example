# ─── Trading Alpha Engine — environment ────────────────────────────────────────
# Copy to .env and fill in. Everything has a sane default except the API keys.
# The pipeline degrades gracefully: a source whose credentials are missing is skipped.

# ── LLM synthesis (cascade) ────────────────────────────────────────────────────
# The synthesis step tries providers in this order and uses the first that answers.
# Providers whose API key is blank below are skipped automatically — so filling in even
# ONE free key makes the whole site work at zero cost. Extra keys are just fallbacks for
# when a free tier hits its rate limit.
LLM_PROVIDER_CHAIN=cerebras,groq,gemini,anthropic
# Discard any insight scoring below this (1-10).
RELEVANCE_THRESHOLD=7
# Bounded daily processing + a rolling "best of" site (keeps LLM spend and the feed small).
# Score at most this many freshest items per run; then keep only the top-N best insights.
SYNTHESIS_MAX_PER_RUN=60
SITE_INSIGHT_TARGET=40
COMMUNITY_INSIGHT_TARGET=20

# Free — Cerebras (https://cloud.cerebras.ai/ → API Keys)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Free — Groq (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Free — Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional paid fallback — Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── GitHub ingestion ───────────────────────────────────────────────────────────
# Optional but strongly recommended — unauthenticated GitHub is rate-limited to 60 req/hr.
GITHUB_TOKEN=

# ── Reddit ingestion ───────────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (type: "script").
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-alpha-engine/0.1 by your_username

# ── Twitter / X (stubbed, disabled) ────────────────────────────────────────────
# The X adapter stays off unless this is true AND a bearer token is set.
TWITTER_ENABLED=false
TWITTER_BEARER_TOKEN=

# StockTwits Firestream is available only to existing/provisioned accounts. The adapter
# stays off unless this flag, sources.yaml, and both credentials are present.
STOCKTWITS_ENABLED=false
STOCKTWITS_USERNAME=
STOCKTWITS_PASSWORD=

# ── Tunables ───────────────────────────────────────────────────────────────────
# Required PostgreSQL connection string (Supabase in production). SQLite is retained only for
# local tests / migration backup. Get both URLs from Supabase → Project Settings → Database.
#   • Vercel read API (serverless) → TRANSACTION pooler, port 6543 + sslmode=require
#       postgresql://postgres.<ref>:<pwd>@aws-...pooler.supabase.com:6543/postgres?sslmode=require
#   • GitHub Actions + local migrate (persistent, IPv4) → SESSION pooler, port 5432 + sslmode=require
#       postgresql://postgres.<ref>:<pwd>@aws-...pooler.supabase.com:5432/postgres?sslmode=require
# (The "Direct connection" db.<ref>.supabase.co:5432 is IPv6-only — GitHub Actions runners are IPv4,
#  so use the Session pooler there.) Set as a Vercel env var / GitHub Secret — NOT committed here.
DATABASE_URL=
# Per-source ingestion cap per run (keeps runs bounded and LLM spend predictable).
MAX_ITEMS_PER_SOURCE=15
# Directory for generated newsletter drafts.
NEWSLETTER_DIR=data/newsletters
# CORS origin allowed by the API (the Vite dev server).
FRONTEND_ORIGIN=http://localhost:5173
